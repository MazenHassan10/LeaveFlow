BETTER_AUTH_SECRET=replace-with-a-random-secret
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
DATABASE_URL=postgresql://user:password@host:5432/database
NEXT_PUBLIC_APP_URL=https://your-production-domain.com

# Gmail API email notifications
GMAIL_CLIENT_ID=replace-with-gmail-oauth-client-id
GMAIL_CLIENT_SECRET=replace-with-gmail-oauth-client-secret
GMAIL_REFRESH_TOKEN=replace-with-gmail-oauth-refresh-token
GMAIL_FROM_EMAIL=notifications@example.com

# Vercel Cron / manual cron protection
CRON_SECRET=replace-with-a-random-cron-secret
